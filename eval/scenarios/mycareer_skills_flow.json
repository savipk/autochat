{
  "name": "mycareer_skills_flow",
  "description": "SkillsCard interaction patterns: infer skills -> card save -> question a skill -> re-analyze -> chat-based save -> improve profile skills trigger",
  "agent": "profile",
  "profile_path": "data/miro_profile.json",
  "turns": [
    {
      "turn": 1,
      "user": "What skills do I have?",
      "expectations": {
        "tool_called": "infer_skills",
        "success": true
      }
    },
    {
      "turn": 2,
      "user": "Save these skills to my profile: A2A, MCP, RAG",
      "expectations": {
        "tool_called": "update_profile",
        "response_contains": ["skills"],
        "success": true
      }
    },
    {
      "turn": 3,
      "user": "Why is MCP listed?",
      "expectations": {
        "tool_not_called": "infer_skills",
        "response_contains": ["MCP"]
      }
    },
    {
      "turn": 4,
      "user": "Re-analyze my skills",
      "expectations": {
        "tool_called": "infer_skills",
        "success": true
      }
    },
    {
      "turn": 5,
      "user": "Add Python and Docker to my skills",
      "expectations": {
        "tool_called": "update_profile",
        "tool_not_called": "infer_skills",
        "response_contains": ["Python", "Docker"],
        "success": true
      }
    },
    {
      "turn": 6,
      "user": "I want to improve my profile skills",
      "expectations": {
        "tool_called": "infer_skills",
        "success": true
      }
    }
  ]
}
